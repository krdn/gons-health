{
  "name": "@krdn/gons-health",
  "license": "UNLICENSED",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krdn/gons-health.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "build:app": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dashboard": "tsx scripts/dashboard.ts",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json --noEmit",
    "verify:kb": "tsx scripts/verifyKb.ts",
    "verify:apply": "tsx scripts/applyVerdict.ts",
    "verify:promote": "tsx scripts/promoteQueue.ts",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
